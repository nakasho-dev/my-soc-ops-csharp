<div class="flex flex-col items-center justify-center min-h-full p-6 bg-sky-gradient">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-xl p-6 shadow-sky border border-gray-200 mb-4 text-center">
            <p class="text-sm text-gray-600 mb-2">Soc Ops • Social Bingo</p>
            <h1 class="text-4xl font-bold text-gray-900 mb-3 leading-tight">Break the ice in minutes</h1>
            <p class="text-gray-700 mb-6">Get everyone talking with quick prompts, friendly challenges, and a race to bingo.</p>

            <button
                @onclick="OnStart"
                class="w-full bg-accent text-white font-semibold py-4 px-8 rounded-lg text-lg active:bg-accent-light transition-colors shadow-sky">
                Start Game
            </button>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sky border border-gray-200">
            <h2 class="font-semibold text-gray-800 mb-3">How it works</h2>
            <ul class="text-left text-gray-600 text-sm">
                <li class="mb-3"><span class="font-semibold text-gray-900">1.</span> Read a prompt and find someone who matches it.</li>
                <li class="mb-3"><span class="font-semibold text-gray-900">2.</span> Tap the square once you get a real match.</li>
                <li><span class="font-semibold text-gray-900">3.</span> Complete 5 in a row and call out bingo.</li>
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
